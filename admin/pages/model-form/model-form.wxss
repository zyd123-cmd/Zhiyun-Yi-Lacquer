.upload-panel {
  margin-top: 28rpx;
}

.upload-panel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.upload-panel__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f2723;
}

.upload-panel__tip {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #8b7f76;
  word-break: break-all;
}

.cover-preview {
  width: 100%;
  height: 360rpx;
  margin-top: 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

.file-id-box {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f9f7f5;
  font-size: 22rpx;
  line-height: 1.6;
  color: #7b6f67;
  word-break: break-all;
}

.submit-button {
  margin-top: 32rpx;
}
