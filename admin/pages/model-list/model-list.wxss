.model-list-title {
  margin-bottom: 0;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8b7f76;
}

.model-card {
  display: flex;
  align-items: flex-start;
  box-sizing: border-box;
  width: 100%;
}

.model-card__cover {
  width: 180rpx;
  height: 180rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #f5f5f5;
}

.model-card__body {
  flex: 1;
  min-width: 0;
  margin-left: 20rpx;
}

.model-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2723;
}

.model-card__meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b6f67;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.model-card__actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8rpx;
  width: 100%;
  margin-top: 20rpx;
}

.model-card__action-button {
  min-width: 0;
}
