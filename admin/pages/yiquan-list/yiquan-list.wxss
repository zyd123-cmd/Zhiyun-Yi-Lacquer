.yiquan-hero__top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.yiquan-hero__content {
  flex: 1;
}

.yiquan-hero__desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8b7f76;
}

.yiquan-hero__refresh {
  margin-top: 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 16rpx;
  background: #fff6ea;
  font-size: 22rpx;
  color: #8a5a16;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8b7f76;
}

.post-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.post-card__nickname {
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2723;
}

.post-card__time,
.post-card__meta {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7b6f67;
}

.post-card__content {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f9f7f5;
  font-size: 26rpx;
  line-height: 1.7;
  color: #433933;
  word-break: break-all;
}

.post-card__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-top: 18rpx;
}

.post-card__image {
  width: 100%;
  height: 190rpx;
  border-radius: 16rpx;
  background: #f1ede8;
}

.post-card__actions {
  margin-top: 20rpx;
}
