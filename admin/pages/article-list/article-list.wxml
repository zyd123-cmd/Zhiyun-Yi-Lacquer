<view class="page-shell">
  <view class="card-panel action-row-spread">
    <view class="section-title article-list-title">文章列表</view>
    <van-button type="danger" size="small" bind:click="goToCreateArticle">发布文章</van-button>
  </view>

  <view wx:if="{{ isLoading }}" class="card-panel loading-panel">
    <van-loading size="24px" color="#8f1d22" />
    <view class="loading-text">文章列表加载中...</view>
  </view>

  <van-empty wx:elif="{{ !articleList.length }}" description="暂无文章数据" />

  <view wx:else class="article-list">
    <view wx:for="{{ articleList }}" wx:key="_id" class="card-panel article-card">
      <image wx:if="{{ item.coverImage }}" src="{{ item.coverImage }}" class="article-card__cover" mode="aspectFill" />
      <view class="article-card__body">
        <view class="article-card__title">{{ item.title }}</view>
        <view class="article-card__meta">作者：{{ item.author || '未填写' }}</view>
        <view class="article-card__meta">分类：{{ item.type || '未分类' }}</view>
        <view class="article-card__meta">更新时间：{{ item.updatedAtText }}</view>
        <view class="action-row article-card__actions">
          <van-button size="small" plain type="primary" data-id="{{ item._id }}" bind:click="editArticle">编辑</van-button>
          <van-button size="small" plain type="danger" data-id="{{ item._id }}" bind:click="deleteArticle">删除</van-button>
        </view>
      </view>
    </view>
  </view>
</view>
