.comment-tip {
  font-size: 24rpx;
  line-height: 1.6;
  color: #8b7f76;
}

.loading-panel {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 18rpx;
}

.loading-text {
  font-size: 24rpx;
  color: #8b7f76;
}

.comment-card__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.comment-card__title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #2f2723;
}

.comment-card__meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #7b6f67;
}

.comment-card__content {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #f9f7f5;
  font-size: 26rpx;
  line-height: 1.7;
  color: #433933;
}

.comment-card__actions {
  margin-top: 20rpx;
}
