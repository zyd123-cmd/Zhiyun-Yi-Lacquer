# -------------------------------------------------
# 1. 依赖目录 (Dependencies)
# -------------------------------------------------
# 根目录下的依赖
node_modules/

# 忽略 wxcomponents 下各个组件库内部的依赖
# 例如：wxcomponents/sse-ai/node_modules
wxcomponents/*/node_modules/


# -------------------------------------------------
# 2. 编译与构建产物 (Build Artifacts)
# -------------------------------------------------
# uni-app 的编译结果目录
unpackage/

# 常见的构建输出目录 (以防万一)
dist/
build/


# -------------------------------------------------
# 3. 系统与环境文件 (System & Env)
# -------------------------------------------------
# 环境变量文件 (建议保留 .env.example，忽略具体的 .env)
.env
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# -------------------------------------------------
# 4. 编辑器配置 (Editor)
# -------------------------------------------------
# VS Code 配置
.vscode/
# 如果你希望共享代码格式化规则，可以取消注释下面这行，只忽略 workspace 设置
# !.vscode/settings.json
# !.vscode/tasks.json
# !.vscode/launch.json
# !.vscode/extensions.json

# IDE 配置
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# =================================================
# 1. 核心依赖 (Dependencies)
# =================================================
# 忽略根目录依赖
node_modules/

# 忽略 wxcomponents 下各个子组件内部的依赖
# 这会匹配 wxcomponents/sse-ai/node_modules
# 也会匹配 wxcomponents/vant/node_modules (如果存在)
wxcomponents/*/node_modules/


# =================================================
# 2. Vant Weapp 特有忽略 (Vant Specifics)
# =================================================
# Vant Weapp 在微信开发者工具中构建后，会在每个组件目录下生成 miniprogram_npm
# 如果你们团队是提交源码（wxcomponents/vant），则需要忽略构建产物
wxcomponents/vant/*/miniprogram_npm/

# 忽略 Vant 可能产生的构建缓存
wxcomponents/vant/.vitepress/
wxcomponents/vant/dist/


# =================================================
# 3. 编译与构建产物 (Build Artifacts)
# =================================================
# uni-app 的编译结果
unpackage/

# 常规构建目录
dist/
build/
coverage/


# =================================================
# 4. 系统与环境文件 (System & Env)
# =================================================
# 环境变量文件 (切记不要上传包含密码的 .env 文件)
.env
.env.local
.env.*.local

# 系统文件
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
.vant/*
!wxcomponents/vant/
!wxcomponents/vant/**
# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =================================================
# 5. 编辑器与IDE (Editors)
# =================================================
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# 本地开发服务器目录
.nuxt/
