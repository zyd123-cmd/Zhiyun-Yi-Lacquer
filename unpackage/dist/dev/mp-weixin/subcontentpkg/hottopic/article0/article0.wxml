<block wx:if="{{isReady}}"><view class="article-container"><ai-assistant vue-id="203f1aba-1" bind:__l="__l"></ai-assistant><view class="article-header"><text class="article-title">{{article.title}}</text><text class="article-source">{{article.author}}</text></view><view class="article-content"><block wx:for="{{articleBlocks}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view><block wx:if="{{item.type==='text'}}"><text class="article-content-text">{{item.content}}</text></block><block wx:else><view class="article-imageview"><image class="article-image" src="{{item.imageSrc}}" mode="widthFix" lazy-load="{{true}}" data-event-opts="{{[['tap',[['openImageActions',['$0'],[[['articleBlocks','',index,'imageSrc']]]]]]]}}" bindtap="__e"></image></view></block></view></block></view><view class="article-actions"><view class="fav-btn-container"><uni-fav vue-id="203f1aba-2" checked="{{isFavorite}}" bg-color-checked="#dd524d" data-event-opts="{{[['^click',[['toggleFavorite']]]]}}" bind:click="__e" bind:__l="__l"></uni-fav></view><view data-event-opts="{{[['tap',[['toggleLike',['$event']]]]]}}" class="handup-container" bindtap="__e"><uni-icons vue-id="203f1aba-3" type="hand-up-filled" size="30rpx" color="{{likeIconColor}}" bind:__l="__l"></uni-icons><text class="handup-text">{{"点赞 "+likeCount}}</text></view></view><view class="comment-section"><view class="comment-section__header"><text class="comment-section__title">{{"评论 "+commentTotalCount}}</text><text class="comment-section__tip">登录后可以发表评论、回复评论和点赞评论</text></view><view class="comment-editor"><block wx:if="{{activeReplyCommentId}}"><view class="comment-editor__replying"><text class="comment-editor__replying-text">{{"正在回复 "+activeReplyNickName}}</text><text data-event-opts="{{[['tap',[['cancelReply',['$event']]]]]}}" class="comment-editor__replying-cancel" bindtap="__e">取消回复</text></view></block><textarea class="comment-editor__textarea" focus="{{isCommentInputFocused}}" maxlength="{{300}}" placeholder="{{commentPlaceholder}}" auto-height="{{true}}" data-event-opts="{{[['input',[['handleCommentInput',['$event']]]],['blur',[['handleCommentInputBlur',['$event']]]]]}}" value="{{commentInput}}" bindinput="__e" bindblur="__e"></textarea><view class="comment-editor__footer"><text class="comment-editor__count">{{commentInputLength+"/300"}}</text><button class="comment-editor__submit" type="primary" size="mini" loading="{{commentSubmitting}}" disabled="{{commentSubmitting}}" data-event-opts="{{[['tap',[['submitComment',['$event']]]]]}}" bindtap="__e">{{''+commentActionButtonText+''}}</button></view></view><block wx:if="{{commentLoading}}"><view class="comment-state-card"><text class="comment-state-card__text">评论加载中，请稍候...</text></view></block><block wx:else><block wx:if="{{commentTotalCount===0}}"><view class="comment-state-card"><text class="comment-state-card__text">还没有评论，来抢沙发吧</text></view></block><block wx:else><view class="comment-list"><block wx:for="{{$root.l1}}" wx:for-item="comment" wx:for-index="__i0__" wx:key="_id"><view class="comment-item"><view class="comment-item__main"><image class="comment-item__avatar" src="{{comment.m0}}" lazy-load="{{true}}"></image><view class="comment-item__body"><view class="comment-item__meta"><text class="comment-item__nickname">{{comment.$orig.nickName}}</text><text class="comment-item__time">{{comment.$orig.createdAtText}}</text></view><text class="{{['comment-item__content',(comment.$orig.isDeleted)?'comment-item__content--deleted':'']}}">{{''+comment.$orig.content+''}}</text><view class="comment-item__actions"><block wx:if="{{!comment.$orig.isDeleted}}"><view data-event-opts="{{[['tap',[['startReply',['$0'],[[['commentTreeData','_id',comment.$orig._id]]]]]]]}}" class="comment-action" bindtap="__e"><uni-icons vue-id="{{'203f1aba-4-'+__i0__}}" type="redo" size="24rpx" color="#888888" bind:__l="__l"></uni-icons><text class="comment-action__text">回复</text></view></block><block wx:if="{{!comment.$orig.isDeleted}}"><view data-event-opts="{{[['tap',[['toggleCommentLike',['$0'],[[['commentTreeData','_id',comment.$orig._id]]]]]]]}}" class="comment-action" bindtap="__e"><uni-icons vue-id="{{'203f1aba-5-'+__i0__}}" type="hand-up-filled" size="24rpx" color="{{comment.m1}}" bind:__l="__l"></uni-icons><text class="comment-action__text">{{"点赞 "+comment.$orig.likeCount}}</text></view></block><block wx:if="{{comment.$orig.canDelete}}"><view data-event-opts="{{[['tap',[['deleteComment',['$0'],[[['commentTreeData','_id',comment.$orig._id]]]]]]]}}" class="comment-action comment-action--danger" bindtap="__e"><uni-icons vue-id="{{'203f1aba-6-'+__i0__}}" type="trash" size="24rpx" color="#c00000" bind:__l="__l"></uni-icons><text class="comment-action__text comment-action__text--danger">删除</text></view></block></view></view></view><block wx:if="{{comment.g0>0}}"><view class="comment-reply-list"><block wx:for="{{comment.l0}}" wx:for-item="reply" wx:for-index="__i1__" wx:key="_id"><view class="comment-reply-item"><image class="comment-reply-item__avatar" src="{{reply.m2}}" lazy-load="{{true}}"></image><view class="comment-reply-item__body"><view class="comment-reply-item__meta"><text class="comment-reply-item__nickname">{{reply.$orig.nickName}}</text><text class="comment-reply-item__time">{{reply.$orig.createdAtText}}</text></view><text class="{{['comment-reply-item__content',(reply.$orig.isDeleted)?'comment-item__content--deleted':'']}}"><block wx:if="{{reply.$orig.replyToNickName}}"><text class="comment-reply-item__reply-tag">{{'回复 '+reply.$orig.replyToNickName+'：'}}</text></block>{{''+reply.$orig.content+''}}</text><view class="comment-item__actions"><block wx:if="{{!reply.$orig.isDeleted}}"><view data-event-opts="{{[['tap',[['startReply',['$0'],[[['commentTreeData','_id',comment.$orig._id],['replies','_id',reply.$orig._id]]]]]]]}}" class="comment-action" bindtap="__e"><uni-icons vue-id="{{'203f1aba-7-'+__i0__+'-'+__i1__}}" type="redo" size="22rpx" color="#888888" bind:__l="__l"></uni-icons><text class="comment-action__text">继续回复</text></view></block><block wx:if="{{!reply.$orig.isDeleted}}"><view data-event-opts="{{[['tap',[['toggleCommentLike',['$0'],[[['commentTreeData','_id',comment.$orig._id],['replies','_id',reply.$orig._id]]]]]]]}}" class="comment-action" bindtap="__e"><uni-icons vue-id="{{'203f1aba-8-'+__i0__+'-'+__i1__}}" type="hand-up-filled" size="22rpx" color="{{reply.m3}}" bind:__l="__l"></uni-icons><text class="comment-action__text">{{"点赞 "+reply.$orig.likeCount}}</text></view></block><block wx:if="{{reply.$orig.canDelete}}"><view data-event-opts="{{[['tap',[['deleteComment',['$0'],[[['commentTreeData','_id',comment.$orig._id],['replies','_id',reply.$orig._id]]]]]]]}}" class="comment-action comment-action--danger" bindtap="__e"><uni-icons vue-id="{{'203f1aba-9-'+__i0__+'-'+__i1__}}" type="trash" size="22rpx" color="#c00000" bind:__l="__l"></uni-icons><text class="comment-action__text comment-action__text--danger">删除</text></view></block></view></view></view></block></view></block></view></block></view></block></block></view></view></block>