<block wx:if="{{isReady}}"><view class="article-container"><ai-assistant vue-id="203f1aba-1" bind:__l="__l"></ai-assistant><view class="article-header"><text class="article-title">{{article.title}}</text><text class="article-source">{{article.author}}</text></view><view class="article-content"><block wx:for="{{alternatedContent}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view><block wx:if="{{item.type==='text'}}"><text class="article-content-text">{{item.content}}</text></block><block wx:else><view class="article-imageview"><image class="article-image" src="{{item.imageSrc}}" mode="widthFix" data-event-opts="{{[['tap',[['openImageActions',['$0'],[[['alternatedContent','',index,'imageSrc']]]]]]]}}" bindtap="__e"></image></view></block></view></block></view><view class="article-actions"><view class="fav-btn-container"><uni-fav vue-id="203f1aba-2" checked="{{isFavorite}}" bg-color-checked="#dd524d" data-event-opts="{{[['^click',[['toggleFavorite']]]]}}" bind:click="__e" bind:__l="__l"></uni-fav></view><view data-event-opts="{{[['tap',[['toggleLike',['$event']]]]]}}" class="handup-container" bindtap="__e"><uni-icons vue-id="203f1aba-3" type="hand-up-filled" size="30rpx" color="{{likeIconColor}}" bind:__l="__l"></uni-icons><text class="handup-text">{{"点赞 "+likeCount}}</text></view></view></view></block>