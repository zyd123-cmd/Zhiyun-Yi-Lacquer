
.hero-image {
  width: 100%;
}
.hero-image__img {
  width: 100%;
}
.navigator-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-around;
  padding: 10rpx;
}
.navigator-item {
  flex: 0 1 calc(50% - 20rpx);
  height: 300rpx;
  margin: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
  transition: -webkit-transform 0.3s ease;
  transition: transform 0.3s ease;
  transition: transform 0.3s ease, -webkit-transform 0.3s ease;
}
.navigator-item:hover {
  -webkit-transform: translateY(-5rpx);
          transform: translateY(-5rpx);
}
.navigator-content {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 10rpx;
}
.navigator-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 10rpx;
}
.navigator-text {
  margin-top: 10rpx;
  color: #333;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

